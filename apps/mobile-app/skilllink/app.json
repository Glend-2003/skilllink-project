{
  "expo": {
    "name": "skilllink",
    "slug": "skilllink",
    "entryPoint": "./node_modules/expo-router/entry",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/skilllink.png",
    "scheme": "skilllink",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Esta aplicación necesita acceso a tu ubicación para mostrar tu dirección en el mapa y conectarte con clientes cercanos."
      },
      "bundleIdentifier": "com.glend2003.skilllink"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.glend2003.skilllink"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permite a SkillLink usar tu ubicación para conectarte con proveedores cercanos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a9e4a356-e519-4d5f-a4fc-111663cfa689"
      }
    },
    "owner": "geraldcc"
  }
}
